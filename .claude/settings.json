{
    "permissions": {
      "allow": [
        "Read", "Edit", "Write", "Grep", "Glob",
        "Bash(dbt compile:*)", "Bash(dbt debug:*)", "Bash(dbt ls:*)", "Bash(dbt parse:*)",
        "Bash(git status:*)", "Bash(git diff:*)", "Bash(git log:*)", "Bash(git branch:*)", "Bash(git add:*)"
      ],
      "ask": [
        "Bash(dbt build:*)", "Bash(dbt run:*)", "Bash(dbt test:*)",
        "Bash(git commit:*)", "Bash(git push:*)", "Bash(gh pr merge:*)"
      ],
      "deny": [
        "Bash(rm -rf:*)", "Bash(git reset --hard:*)", "Bash(git push --force:*)", "Bash(git push -f:*)",
        "Read(.env)", "Read(**/.env)", "Read(**/*key*.json)"
      ]
    }
  }